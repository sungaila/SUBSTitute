<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Sungaila.SUBSTitute.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:CommunityToolkit.WinUI.Controls"
      xmlns:converters="using:Sungaila.SUBSTitute.Converters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:e="using:Microsoft.UI.Xaml"
      xmlns:enums="using:Sungaila.SUBSTitute.Enums"
      xmlns:i="using:Microsoft.Xaml.Interactivity"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:tkconverters="using:CommunityToolkit.WinUI.Converters"
      xmlns:ui="using:CommunityToolkit.WinUI"
      xmlns:viewmodels="using:Sungaila.SUBSTitute.ViewModels"
      d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
      Loading="Page_Loading"
      mc:Ignorable="d">
    <Page.Resources>
        <converters:EnumToStringConverter x:Key="EnumToStringConverter" />
        <converters:ElementThemeToIntConverter x:Key="ElementThemeToIntConverter" />
        <tkconverters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <DataTemplate x:Key="RadioButtonsItemTemplate" x:DataType="e:ElementTheme">
            <TextBlock Text="{x:Bind Mode=OneTime, Converter={StaticResource EnumToStringConverter}}" />
        </DataTemplate>
    </Page.Resources>

    <ScrollView DataContext="{x:Bind Data.Settings}"
                HorizontalScrollMode="Disabled"
                VerticalScrollMode="Auto">
        <Grid Margin="15,6,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="5" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="5" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="5" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="5" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Uid="SettingsHeaderTextBlock"
                       Grid.Row="0"
                       Style="{StaticResource TitleTextBlockStyle}" />

            <controls:SettingsCard x:Uid="LanguageSettingsCard"
                                   Grid.Row="2"
                                   HeaderIcon="{ui:FontIcon Glyph=&#xF2B7;}">
                <ComboBox x:Uid="LanguageComboBox"
                          AutomationProperties.Name="{Binding Header, RelativeSource={RelativeSource Mode=TemplatedParent}}"
                          DisplayMemberPath="DisplayName"
                          ItemsSource="{x:Bind viewmodels:SettingsViewModel.AvailableLanguages, Mode=OneTime}"
                          Loaded="ComboBox_Loaded"
                          SelectedItem="{x:Bind Data.Settings.SelectedLanguage, Mode=TwoWay}" />
            </controls:SettingsCard>

            <controls:SettingsExpander x:Uid="ThemeSettingsCard"
                                       Grid.Row="4"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                <controls:SettingsExpander.Items>
                    <controls:SettingsCard ContentAlignment="Left">
                        <RadioButtons ItemTemplate="{StaticResource RadioButtonsItemTemplate}"
                                      ItemsSource="{x:Bind Data.Settings.AvailableThemes}"
                                      MaxColumns="1"
                                      SelectedIndex="{x:Bind Data.Settings.SelectedTheme, Mode=TwoWay, Converter={StaticResource ElementThemeToIntConverter}}" />
                    </controls:SettingsCard>
                </controls:SettingsExpander.Items>
            </controls:SettingsExpander>

            <controls:SettingsCard x:Uid="PatternCanvasVisibleSettingsCard"
                                   Grid.Row="6"
                                   HeaderIcon="{ui:FontIcon Glyph=&#xE8B9;}">
                <ToggleSwitch IsOn="{x:Bind Data.Settings.PatternCanvasVisible, Mode=TwoWay}" />
            </controls:SettingsCard>

            <controls:SettingsCard x:Uid="IssueSettingsCard"
                                   Grid.Row="8"
                                   ActionIcon="{ui:FontIcon Glyph=&#xE8A7;}"
                                   ActionIconToolTip="https://github.com/sungaila/SUBSTitute/issues"
                                   Click="SettingsCard_Click"
                                   HeaderIcon="{ui:FontIcon Glyph=&#xEBE8;}"
                                   IsClickEnabled="True" />

            <controls:SettingsCard x:Uid="TranslationSettingsCard"
                                   Grid.Row="10"
                                   ActionIcon="{ui:FontIcon Glyph=&#xE8A7;}"
                                   ActionIconToolTip="https://hosted.weblate.org/engage/substitute/"
                                   Click="SettingsCard_Click"
                                   HeaderIcon="{ui:FontIcon Glyph=&#xF87B;}"
                                   IsClickEnabled="True" />

            <controls:SettingsCard x:Uid="AutoUpdateSettingsCard"
                                   Grid.Row="11"
                                   Margin="0,5,0,0"
                                   HeaderIcon="{ui:FontIcon Glyph=&#xE895;}"
                                   Visibility="{x:Bind viewmodels:SettingsViewModel.IsManagedByAppInstaller, Mode=OneTime, Converter={StaticResource BoolToVisibilityConverter}}">
                <SplitButton x:Uid="CheckForUpdatesSplitButton"
                             Command="{x:Bind Data.Settings.CheckForUpdatesCommand}"
                             CommandParameter="{x:Bind Data.Settings}">
                    <SplitButton.Flyout>
                        <MenuFlyout>
                            <RadioMenuFlyoutItem x:Uid="CheckForUpdatesWeeklyRadioMenuFlyoutItem" IsChecked="{x:Bind Data.Settings.IsAutoUpdateWeekly, Mode=TwoWay}" />
                            <RadioMenuFlyoutItem x:Uid="CheckForUpdatesDailyRadioMenuFlyoutItem" IsChecked="{x:Bind Data.Settings.IsAutoUpdateDaily, Mode=TwoWay}" />
                            <RadioMenuFlyoutItem x:Uid="CheckForUpdatesHourlyRadioMenuFlyoutItem" IsChecked="{x:Bind Data.Settings.IsAutoUpdateHourly, Mode=TwoWay}" />
                            <RadioMenuFlyoutItem x:Uid="CheckForUpdatesOnLaunchRadioMenuFlyoutItem" IsChecked="{x:Bind Data.Settings.IsAutoUpdateOnLaunch, Mode=TwoWay}" />
                            <MenuFlyoutSeparator />
                            <RadioMenuFlyoutItem x:Uid="CheckForUpdatesOffRadioMenuFlyoutItem" IsChecked="{x:Bind Data.Settings.IsAutoUpdateOff, Mode=TwoWay}" />
                        </MenuFlyout>
                    </SplitButton.Flyout>
                </SplitButton>
            </controls:SettingsCard>

            <TextBlock x:Uid="AppInfoTextBlock"
                       Grid.Row="13"
                       Style="{StaticResource BodyStrongTextBlockStyle}" />

            <TextBlock x:Name="AppNameTextBlock"
                       Grid.Row="14"
                       IsTextSelectionEnabled="True" />

            <TextBlock x:Name="AuthorTextBlock"
                       Grid.Row="15"
                       IsTextSelectionEnabled="True" />

            <controls:WrapPanel Grid.Row="17"
                                HorizontalSpacing="5"
                                Orientation="Horizontal">
                <HyperlinkButton x:Name="StoreHyperlinkButton"
                                 x:Uid="StoreHyperlinkButton"
                                 NavigateUri="https://www.microsoft.com/store/apps/9NGPRNJJKLBG"
                                 ToolTipService.ToolTip="{x:Bind StoreHyperlinkButton.NavigateUri, Mode=OneTime}" />

                <HyperlinkButton x:Name="GitHubHyperlinkButton"
                                 x:Uid="GitHubHyperlinkButton"
                                 NavigateUri="https://github.com/sungaila/SUBSTitute"
                                 ToolTipService.ToolTip="{x:Bind GitHubHyperlinkButton.NavigateUri, Mode=OneTime}" />

                <HyperlinkButton x:Name="WeblateHyperlinkButton"
                                 x:Uid="WeblateHyperlinkButton"
                                 NavigateUri="https://hosted.weblate.org/projects/substitute/"
                                 ToolTipService.ToolTip="{x:Bind WeblateHyperlinkButton.NavigateUri, Mode=OneTime}" />

                <HyperlinkButton x:Name="SungailaHyperlinkButton"
                                 x:Uid="SungailaHyperlinkButton"
                                 NavigateUri="https://www.sungaila.de"
                                 ToolTipService.ToolTip="{x:Bind SungailaHyperlinkButton.NavigateUri, Mode=OneTime}" />
            </controls:WrapPanel>
        </Grid>
    </ScrollView>
</Page>